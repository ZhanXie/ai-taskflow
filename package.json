{
  "name": "ai-taskflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:local": "bash scripts/start-local.sh",
    "dev:db": "docker compose up -d && sleep 5 && npm run db:migrate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset",
    "db:push": "prisma db push",
    "db:pull": "prisma db pull",
    "clean": "rm -rf .next dist node_modules && npm install",
    "clean:cache": "rm -rf .next",
    "format": "prettier --write .",
    "pre-deploy": "bash scripts/pre-deploy-check.sh",
    "deploy:staging": "npm run pre-deploy && echo 'Ready for staging deployment'",
    "deploy:production": "npm run pre-deploy && echo 'Ready for production deployment'"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@clerk/nextjs": "^7.0.8",
    "@prisma/client": "^6.19.3",
    "ai": "^6.0.142",
    "clerk": "^0.8.3",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tencentcloud-sdk-nodejs": "^4.1.204",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10.1.0",
    "eslint-config-next": "16.2.2",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^6.0.2"
  }
}