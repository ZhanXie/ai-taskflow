{
  "name": "ai-taskflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:up": "docker compose up -d && sleep 3 && npm run db:generate && npm run db:push && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:deploy": "npm run db:generate && npm run db:migrate",
    "setup": "npm install && npm run db:generate && npm run db:push"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.0",
    "@clerk/nextjs": "^7.0.8",
    "@prisma/client": "^6.19.3",
    "ai": "^6.0.142",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.2",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^6.0.2"
  }
}