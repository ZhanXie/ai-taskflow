# Database (PostgreSQL)
# Used by Prisma to connect to the database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_taskflow?schema=public"

# Clerk Authentication
# Get these from https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"

# OpenAI API
# Get this from https://platform.openai.com/api-keys
OPEN_API_KEY=
OPEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPEN_MODEL=qwen-plus
